# Environment variables for the Recovery Detector API.
# Copy to .env for local dev (python-dotenv loads it). Never commit real secrets.

# ── Existing (unchanged) ──────────────────────────────────────────────────────
# Top financial-news headline for held tickers (product/api/main.py). Optional.
NEWS_API_KEY=
# Comma-separated allowed CORS origins. Defaults to "*" if unset.
ALLOWED_ORIGINS=
# SEC EDGAR User-Agent ("AppName contact@email"). Optional; has a safe default.
EDGAR_USER_AGENT=

# ── Supabase (Phase 1 — set to stand up auth; not yet read by any endpoint) ───
# Project URL, e.g. https://<project-ref>.supabase.co   (public / frontend-safe)
SUPABASE_URL=
# Anon/public API key   (public / frontend-safe)
SUPABASE_ANON_KEY=
# JWT signing secret — BACKEND ONLY. Never expose to the client. Used in Phase 2
# to verify the Supabase access token on gated endpoints.
SUPABASE_JWT_SECRET=
